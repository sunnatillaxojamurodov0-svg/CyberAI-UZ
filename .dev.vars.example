# Cloudflare Workers secrets (for local dev with `npx wrangler dev`)
# Copy to .dev.vars and fill in values.
# NEVER commit .dev.vars or .env to version control.

# Google Gemini API key (server-side only)
GEMINI_API_KEY="your-gemini-api-key-here"

# GitHub OAuth (create an OAuth App: https://github.com/settings/developers)
# Callback URL: http://localhost:8080/auth/callback
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"
