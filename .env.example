# ═══════════════════════════════════════════════════════════════════
# CyberAI Environment Variables
# ═══════════════════════════════════════════════════════════════════
# Copy this file to .dev.vars and fill in your values.
# NEVER commit .dev.vars or .env to version control.
# ═══════════════════════════════════════════════════════════════════
# ─── Authentication ───────────────────────────────────────────────

# GitHub OAuth (create: https://github.com/settings/developers)
# Callback URL: http://localhost:8080/auth/callback
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# Google OAuth (create: https://console.cloud.google.com/apis/credentials)
# Callback URL: http://localhost:8080/auth/callback
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── Email Service ────────────────────────────────────────────────

# Resend API key (for transactional emails)
# Get: https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxx"

# ─── Payment Processing ───────────────────────────────────────────

# Stripe API keys (for subscription billing)
# Get: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxx"

# ─── Docker Integration ───────────────────────────────────────────

# Docker API key (for container management)
DOCKER_API_KEY="your-docker-api-key"

# Docker Proxy URL (production endpoint)
DOCKER_PROXY_URL="https://docker.cyberaiuz.workers.dev"

# ─── Cloudflare Configuration ────────────────────────────────────

# Cloudflare API token (for deployment)
CLOUDFLARE_API_TOKEN="your-cloudflare-api-token"

# Cloudflare Zone ID (for WAF rules)
CLOUDFLARE_ZONE_ID="your-zone-id"

# ─── Application Settings ─────────────────────────────────────────

# Application URL (for email links, redirects)
APP_URL="https://app.cyberaiuz.workers.dev"

# Environment (development | production)
ENVIRONMENT="development"

# ─── Feature Flags ────────────────────────────────────────────────

# Enable/disable features
ENABLE_REGISTRATION="true"
ENABLE_CHAT="true"
ENABLE_CONSOLE="true"
ENABLE_2FA="true"

# ─── Rate Limiting ────────────────────────────────────────────────

# Requests per minute (global)
RATE_LIMIT_GLOBAL=100

# Auth attempts per minute
RATE_LIMIT_AUTH=5

# Chat requests per minute
RATE_LIMIT_CHAT=20

# ─── Account Lockout ──────────────────────────────────────────────

# Failed login attempts before lockout
MAX_LOGIN_ATTEMPTS=5

# Lockout duration in minutes
LOCKOUT_DURATION_MINUTES=15
