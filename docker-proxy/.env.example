# ============================================
# CyberAI Docker Proxy - Environment Variables
# ============================================

# API Security (required)
DOCKER_API_KEY=your_api_key_here

# Container Limits
MAX_CONTAINERS=10
CONTAINER_TTL_MS=14400000

# CORS (comma-separated)
ALLOWED_ORIGINS=https://app.cyberaiuz.workers.dev

# Cloudflare Tunnel (get from dashboard)
CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token_here

# Cleanup Interval (seconds)
CLEANUP_INTERVAL=300

# Node Environment
NODE_ENV=production
